    title: '', titleUrdu: '', content: '', contentUrdu: '', category: '', categoryUrdu: '', imageUrl: '',
    titleFont: '', titleUrduFont: '', contentFont: '', contentUrduFont: ''
  });

  const englishFonts = [
    { name: 'Default', value: '' },
    { name: 'Inter', value: "'Inter', sans-serif" },
    { name: 'Playfair Display', value: "'Playfair Display', serif" },
    ...(settings?.customFonts || []).filter((f: any) => f.type === 'english').map((f: any) => ({ name: f.name, value: `'${f.family}', sans-serif` }))
  ];

  const urduFonts = [
    { name: 'Default', value: '' },
    { name: 'Jameel Noori Nastaleeq', value: "'Jameel Noori Nastaleeq', serif" },
    { name: 'Noto Nastaliq Urdu', value: "'Noto Nastaliq Urdu', serif" },
    { name: 'Al Qalam Quran Majeed', value: "'Al Qalam Quran Majeed Web Regular', serif" },
    ...(settings?.customFonts || []).filter((f: any) => f.type === 'urdu').map((f: any) => ({ name: f.name, value: `'${f.family}', sans-serif` }))
  ];

  useEffect(() => {
    const q = query(collection(db, 'articles'), orderBy('createdAt', 'desc'));
    const unsubscribe = onSnapshot(q, (snapshot) => {
      setArticles(snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() } as Article)));
      setLoading(false);
    }, (error) => {
      handleFirestoreError(error, OperationType.LIST, 'articles');
      setLoading(false);
    });
    return () => unsubscribe();
  }, []);

  const handleSave = async (e: React.FormEvent) => {
    e.preventDefault();
    const path = 'articles';
    try {
      if (editingItem) {
        await updateDoc(doc(db, path, editingItem.id), { ...formData });
        showToast("Article updated successfully!");
      } else {
        await addDoc(collection(db, path), { ...formData, createdAt: serverTimestamp() });
        showToast("Article created successfully!");
      }
      setIsModalOpen(false);
      setEditingItem(null);
      setFormData({ title: '', titleUrdu: '', content: '', contentUrdu: '', category: '', categoryUrdu: '', imageUrl: '' });
    } catch (error) {
      handleFirestoreError(error, editingItem ? OperationType.UPDATE : OperationType.CREATE, path);
      showToast("Operation failed. Check permissions.", "error");
    }
  };

  const handleDelete = async (id: string) => {
    confirmAction(
      "Delete Article",
      "Are you sure you want to delete this article? This action cannot be undone.",
      async () => {
        const path = 'articles';
        try {
          await deleteDoc(doc(db, path, id));
          showToast("Article deleted successfully!");
        } catch (error) {
          handleFirestoreError(error, OperationType.DELETE, path);
          showToast("Delete failed. Check permissions.", "error");
        }
      }
    );
