const AdminPlaylists = ({ showToast, confirmAction }: any) => {
  const [playlists, setPlaylists] = useState<Playlist[]>([]);
  const [loading, setLoading] = useState(true);
  const [isModalOpen, setIsModalOpen] = useState(false);
  const [editingPlaylist, setEditingPlaylist] = useState<Playlist | null>(null);
  const [activePlaylistId, setActivePlaylistId] = useState<string | null>(null);
  const [isUploading, setIsUploading] = useState(false);

  const [playlistForm, setPlaylistForm] = useState<{
    title: string;
    titleUrdu: string;
    coverUrl: string;
    videos: Video[];
  }>({
    title: '', titleUrdu: '', coverUrl: '', videos: []
  });

  const [videoInput, setVideoInput] = useState({
    title: '', titleUrdu: '', youtubeUrl: ''
  });

  useEffect(() => {
    const q = query(collection(db, 'playlists'), orderBy('createdAt', 'desc'));
    const unsubscribe = onSnapshot(q, (snapshot) => {
      setPlaylists(snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() } as Playlist)));
      setLoading(false);
    });
    return () => unsubscribe();
  }, []);

  const handleAddVideoToList = () => {
    if (!videoInput.youtubeUrl || !videoInput.title) {
      showToast("Please provide video title and URL", "error");
      return;
    }

    // Auto-thumbnail logic
    const getYouTubeID = (url: string) => {
      const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
      const match = url.match(regExp);
      return (match && match[2].length === 11) ? match[2] : null;
    };

    const videoId = getYouTubeID(videoInput.youtubeUrl);
    if (videoId) {
      const thumbnailUrl = `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`;
      
      const newVideo: Video = {
        id: Date.now().toString(),
        title: videoInput.title,
        titleUrdu: videoInput.titleUrdu,
        youtubeUrl: videoInput.youtubeUrl,
        thumbnailUrl,
        order: playlistForm.videos.length + 1
      };

      setPlaylistForm({
        ...playlistForm,
        videos: [...playlistForm.videos, newVideo]
      });

      setVideoInput({ title: '', titleUrdu: '', youtubeUrl: '' });
      showToast("Video added to list!");
    } else {
      showToast("Invalid YouTube URL", "error");
    }
  };

  const handleRemoveVideoFromList = (id: string) => {
    setPlaylistForm({
      ...playlistForm,
      videos: playlistForm.videos.filter(v => v.id !== id)
    });
  };

  const handleSavePlaylist = async (e: React.FormEvent) => {
    e.preventDefault();
    if (isUploading) return;
    if (!playlistForm.title || !playlistForm.coverUrl) {
      showToast("Please provide title and cover image", "error");
      return;
    }

    const path = 'playlists';
    try {
      if (editingPlaylist) {
