              <div className="absolute top-2 right-2 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                <button onClick={() => { setEditingItem(item); setFormData(item); setIsModalOpen(true); }} className="p-2 bg-white/90 dark:bg-stone-900/90 text-blue-500 rounded-lg shadow-lg hover:scale-110 transition-all"><Edit size={16} /></button>
                <button onClick={() => handleDelete(item.id)} className="p-2 bg-white/90 dark:bg-stone-900/90 text-red-500 rounded-lg shadow-lg hover:scale-110 transition-all"><Trash2 size={16} /></button>
              </div>
            </div>
            <h4 className="font-bold text-stone-900 dark:text-white mb-1 line-clamp-1">{item.title}</h4>
            <p className="text-xs text-stone-500 font-urdu line-clamp-1" dir="rtl">{item.titleUrdu}</p>
          </div>
        ))}
      </div>

      <Modal isOpen={isModalOpen} onClose={() => setIsModalOpen(false)} title={editingItem ? "Edit Article" : "Add Article"}>
        <form onSubmit={handleSave} className="space-y-6">
          <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
