                      <span className="text-[8px] uppercase text-orange-500 font-bold tracking-widest">{font.type}</span>
                    </div>
                  </div>
                  <button 
                    onClick={() => removeFont(index)}
                    className="p-2 text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition-colors"
                  >
                    <Trash2 size={16} />
                  </button>
                </div>
              ))}
            </div>
          )}
        </div>

        <div className="mt-12 pt-8 border-t border-stone-200 dark:border-stone-800 flex justify-end">
          <button 
            onClick={handleSave}
            disabled={saving}
            className="bg-orange-600 text-white px-10 py-3 rounded-xl font-bold flex items-center gap-2 shadow-lg shadow-orange-600/20"
          >
            <Save size={20} /> {saving ? 'Saving...' : 'Apply Global Settings'}
          </button>
        </div>
      </div>
    </div>
  );
};

const AdminHome = ({ showToast }: any) => {
  const [settings, setSettings] = useState<any>(null);
  const [loading, setLoading] = useState(true);
  const [saving, setSaving] = useState(false);

  useEffect(() => {
    const unsubscribe = onSnapshot(doc(db, 'config', 'main'), (snapshot) => {
      if (snapshot.exists()) {
        setSettings(snapshot.data());
      }
      setLoading(false);
    }, (error) => {
      handleFirestoreError(error, OperationType.GET, 'config/main');
      setLoading(false);
    });
    return () => unsubscribe();
  }, []);

  const handleSave = async (e: React.FormEvent) => {
    e.preventDefault();
    setSaving(true);
    const path = 'config/main';
    try {
      await setDoc(doc(db, 'config', 'main'), settings, { merge: true });
      showToast("Home content saved!");
    } catch (error) {
      handleFirestoreError(error, OperationType.WRITE, path);
      showToast("Save failed. Check permissions.", "error");
    } finally {
      setSaving(false);
    }
  };

  if (loading || !settings) return <LoadingSpinner />;

  return (
    <div className="max-w-4xl mx-auto bg-white dark:bg-stone-900 p-8 rounded-3xl border border-stone-200 dark:border-stone-800 shadow-xl">
      <div className="flex items-center gap-4 mb-8">
        <div className="w-12 h-12 bg-orange-500/10 rounded-2xl flex items-center justify-center text-orange-500">
          <HomeIcon size={24} />
        </div>
        <div>
          <h3 className="text-xl font-bold text-stone-900 dark:text-white">Homepage Content</h3>
          <p className="text-sm text-stone-500">Customize your website's hero section and introduction</p>
        </div>
      </div>

      <form onSubmit={handleSave} className="space-y-8">
        <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
          <FormField label="Hero Heading (English)" value={settings.homeHeading} onChange={(v: any) => setSettings({...settings, homeHeading: v})} />
          <FormField label="Hero Heading (Urdu)" labelUrdu="ہیرو سرخی" value={settings.homeHeadingUrdu} onChange={(v: any) => setSettings({...settings, homeHeadingUrdu: v})} dir="rtl" />
        </div>
        <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
          <FormField label="Hero Subheading (English)" value={settings.homeSubheading} onChange={(v: any) => setSettings({...settings, homeSubheading: v})} />
          <FormField label="Hero Subheading (Urdu)" labelUrdu="ہیرو ذیلی سرخی" value={settings.homeSubheadingUrdu} onChange={(v: any) => setSettings({...settings, homeSubheadingUrdu: v})} dir="rtl" />
        </div>
        <FileUpload label="Hero Image" currentUrl={settings.homeImageUrl} onUpload={(url: any) => setSettings({...settings, homeImageUrl: url})} showToast={showToast} />
        <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
          <FormField label="Intro Text (English)" isTextArea value={settings.homeText} onChange={(v: any) => setSettings({...settings, homeText: v})} />
          <FormField label="Intro Text (Urdu)" labelUrdu="تعارفی متن" isTextArea value={settings.homeTextUrdu} onChange={(v: any) => setSettings({...settings, homeTextUrdu: v})} dir="rtl" />
        </div>
        <div className="flex justify-end pt-4 border-t border-stone-100 dark:border-stone-800">
          <button type="submit" disabled={saving} className="bg-orange-600 text-white px-10 py-3 rounded-xl font-bold flex items-center gap-2 shadow-lg shadow-orange-600/20 hover:scale-105 transition-transform disabled:opacity-50 disabled:hover:scale-100">
            <Save size={20} /> {saving ? 'Saving...' : 'Save Content'}
          </button>
        </div>
      </form>
    </div>
  );
};

