                <div className="w-10 h-10 bg-orange-500/10 rounded-full flex items-center justify-center text-orange-500">
                  <Upload size={20} />
                </div>
                <span className="text-[10px] font-bold text-stone-600 dark:text-stone-400 uppercase tracking-widest">English Font</span>
