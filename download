const AdminSettings = ({ showToast }: any) => {
  const [settings, setSettings] = useState<any>(null);
  const [loading, setLoading] = useState(true);
  const [saving, setSaving] = useState(false);
  const [uploadingFont, setUploadingFont] = useState(false);

  useEffect(() => {
    const unsubscribe = onSnapshot(doc(db, 'config', 'main'), (snapshot) => {
      if (snapshot.exists()) {
        setSettings(snapshot.data());
      } else {
        setSettings({
          headingFont: "'Inter', sans-serif",
          bodyFont: "'Inter', sans-serif",
          urduFont: "'Noto Naskh Arabic', serif",
          customFonts: []
        });
      }
      setLoading(false);
    }, (error) => {
      handleFirestoreError(error, OperationType.GET, 'config/main');
      setLoading(false);
    });
    return () => unsubscribe();
  }, []);

  const handleSave = async (e: React.FormEvent) => {
    e.preventDefault();
    setSaving(true);
    const path = 'config/main';
    try {
      await setDoc(doc(db, 'config', 'main'), settings, { merge: true });
      showToast("Site settings saved!");
    } catch (error) {
      handleFirestoreError(error, OperationType.WRITE, path);
      showToast("Save failed. Check permissions.", "error");
    } finally {
      setSaving(false);
    }
  };

  const handleFontUpload = async (e: React.ChangeEvent<HTMLInputElement>, type: 'english' | 'urdu') => {
    const file = e.target.files?.[0];
    if (!file) return;
    
    const extension = file.name.split('.').pop()?.toLowerCase();
    if (!['ttf', 'otf', 'woff', 'woff2'].includes(extension || '')) {
      showToast("Please upload a valid font file (.ttf, .otf, .woff)", "error");
      return;
    }

    setUploadingFont(true);
    try {
      const storageRef = ref(storage, `fonts/${Date.now()}_${file.name}`);
      const uploadTask = uploadBytesResumable(storageRef, file);
      
      uploadTask.on('state_changed',
        (snapshot) => {
          const p = (snapshot.bytesTransferred / snapshot.totalBytes) * 100;
          console.log(`Font upload progress: ${p}%`);
        },
        (error) => {
          console.error("Font upload failed:", error);
          alert(`Font upload failed: ${error.message} (Code: ${error.code})`);
          showToast("Font upload failed", "error");
          setUploadingFont(false);
        },
        async () => {
          try {
            const url = await getDownloadURL(uploadTask.snapshot.ref);
            const familyName = file.name.split('.')[0].replace(/[^a-zA-Z0-9]/g, '-');
            
            const newFont = { name: file.name, url, family: familyName, type };
            const updatedFonts = [...(settings.customFonts || []), newFont];
            
            setSettings({ ...settings, customFonts: updatedFonts });
            showToast("Font uploaded successfully!");
          } catch (urlError: any) {
            console.error("Error getting font download URL:", urlError);
            alert(`Error getting font download URL: ${urlError.message}`);
          } finally {
            setUploadingFont(false);
          }
        }
      );
    } catch (error: any) {
      console.error("Font upload initialization failed:", error);
      alert(`Font upload initialization failed: ${error.message}`);
      showToast("Font upload failed", "error");
      setUploadingFont(false);
    }
  };

  const removeFont = (index: number) => {
    const updatedFonts = [...settings.customFonts];
    updatedFonts.splice(index, 1);
    setSettings({ ...settings, customFonts: updatedFonts });
  };

  if (loading || !settings) return <LoadingSpinner />;

  const fontOptions = [
    { name: 'Inter', value: "'Inter', sans-serif" },
    { name: 'Playfair Display', value: "'Playfair Display', serif" },
    { name: 'Space Grotesk', value: "'Space Grotesk', sans-serif" },
    { name: 'Outfit', value: "'Outfit', sans-serif" },
    { name: 'JetBrains Mono', value: "'JetBrains Mono', monospace" },
    { name: 'Noto Naskh Arabic', value: "'Noto Naskh Arabic', serif" },
    ...(settings.customFonts || []).map((f: any) => ({ name: f.name, value: `'${f.family}', sans-serif` }))
  ];

  return (
    <div className="max-w-4xl mx-auto space-y-8">
      <div className="bg-white dark:bg-stone-900 p-8 rounded-3xl border border-stone-200 dark:border-stone-800 shadow-xl">
        <h3 className="text-xl font-bold text-stone-900 dark:text-white mb-8 flex items-center gap-2">
          <Settings size={24} className="text-orange-500" /> Font Management
        </h3>
        
        <div className="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
          <div className="space-y-4">
            <label className="block text-xs font-bold text-stone-500 uppercase tracking-widest">Global Heading Font</label>
            <select 
              value={settings.headingFont}
              onChange={(e) => setSettings({...settings, headingFont: e.target.value})}
              className="w-full px-4 py-3 rounded-xl border border-stone-200 dark:border-stone-800 bg-stone-50 dark:bg-black text-stone-900 dark:text-white focus:ring-2 focus:ring-orange-500/20 outline-none transition-all"
            >
              {fontOptions.map(f => <option key={f.value} value={f.value}>{f.name}</option>)}
            </select>
          </div>
          <div className="space-y-4">
            <label className="block text-xs font-bold text-stone-500 uppercase tracking-widest">Global Body Font</label>
            <select 
              value={settings.bodyFont}
              onChange={(e) => setSettings({...settings, bodyFont: e.target.value})}
              className="w-full px-4 py-3 rounded-xl border border-stone-200 dark:border-stone-800 bg-stone-50 dark:bg-black text-stone-900 dark:text-white focus:ring-2 focus:ring-orange-500/20 outline-none transition-all"
            >
              {fontOptions.map(f => <option key={f.value} value={f.value}>{f.name}</option>)}
            </select>
          </div>
        </div>

        <div className="space-y-6">
          <label className="block text-xs font-bold text-stone-500 uppercase tracking-widest">Upload Custom Fonts (.ttf, .otf)</label>
          <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div className="border-2 border-dashed border-stone-200 dark:border-stone-800 rounded-2xl p-6 text-center hover:border-orange-500/50 transition-colors">
              <input type="file" id="font-upload-en" className="hidden" accept=".ttf,.otf,.woff,.woff2" onChange={(e) => handleFontUpload(e, 'english')} disabled={uploadingFont} />
