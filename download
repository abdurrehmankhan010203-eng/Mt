const FileUpload = ({ label, onUpload, accept, currentUrl, type = "image", showToast, onUploadingStateChange }: any) => {
  const [uploading, setUploading] = useState(false);
  const [progress, setProgress] = useState(0);
  const fileInputRef = useRef<HTMLInputElement>(null);

  const handleFileChange = async (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (!file) return;
    
    setUploading(true);
    if (onUploadingStateChange) onUploadingStateChange(true);
    setProgress(0);
    
    try {
      const storageRef = ref(storage, `uploads/${Date.now()}_${file.name}`);
      const uploadTask = uploadBytesResumable(storageRef, file);
      
      uploadTask.on('state_changed', 
        (snapshot) => {
          const p = (snapshot.bytesTransferred / snapshot.totalBytes) * 100;
          if (!isNaN(p)) {
            setProgress(p);
            console.log(`Upload progress: ${p}%`);
          }
        }, 
        (error) => {
          console.error("Upload failed:", error);
          alert(`Upload failed: ${error.message} (Code: ${error.code})`);
          if (error.code === 'storage/unauthorized') {
            if (showToast) showToast("Permission denied. You must be an admin to upload.", "error");
          } else {
            if (showToast) showToast("Upload failed. Please try again.", "error");
          }
          setUploading(false);
          if (onUploadingStateChange) onUploadingStateChange(false);
        }, 
        async () => {
          // Ensure we are at 100% before getting the URL
          setProgress(100);
          try {
            const url = await getDownloadURL(uploadTask.snapshot.ref);
            onUpload(url);
            if (showToast) showToast("File uploaded successfully!");
          } catch (urlError: any) {
            console.error("Error getting download URL:", urlError);
            alert(`Error getting download URL: ${urlError.message}`);
          } finally {
            setTimeout(() => {
              setUploading(false);
              if (onUploadingStateChange) onUploadingStateChange(false);
              setProgress(0);
            }, 500);
          }
        }
      );
    } catch (error: any) {
      console.error("Upload initialization failed:", error);
      alert(`Upload initialization failed: ${error.message}`);
      if (showToast) showToast("Upload failed. Please try again.", "error");
      setUploading(false);
      if (onUploadingStateChange) onUploadingStateChange(false);
    }
  };

  return (
    <div className="space-y-2">
      <label className="text-xs font-bold text-stone-500 uppercase tracking-widest">{label}</label>
      <div className="relative group overflow-hidden rounded-2xl border border-dashed border-stone-300 dark:border-stone-700 aspect-video flex items-center justify-center bg-stone-50 dark:bg-stone-900/50">
        {currentUrl ? (
          type === "image" ? (
            <img src={currentUrl} className="w-full h-full object-cover" referrerPolicy="no-referrer" />
          ) : (
            <div className="flex flex-col items-center gap-2">
              <Book size={48} className="text-orange-500" />
              <span className="text-xs font-bold text-stone-500">PDF Uploaded</span>
            </div>
          )
        ) : (
          <div className="flex flex-col items-center gap-2 text-stone-400">
            <Upload size={32} />
            <span className="text-xs font-bold">Click to upload</span>
          </div>
        )}
        
        {uploading && (
          <div className="absolute inset-0 bg-black/60 flex flex-col items-center justify-center p-4">
            <div className="w-full max-w-[120px] bg-white/20 h-1.5 rounded-full overflow-hidden mb-2">
              <motion.div 
                initial={{ width: 0 }}
                animate={{ width: `${progress}%` }}
                className="h-full bg-orange-500"
              />
            </div>
            <span className="text-[10px] font-bold text-white uppercase tracking-widest">{Math.round(progress)}% Uploading</span>
          </div>
        )}

        {!uploading && (
          <label className="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer flex items-center justify-center">
            <span className="text-white font-bold text-sm">Change File</span>
            <input type="file" ref={fileInputRef} className="hidden" onChange={handleFileChange} accept={accept} />
          </label>
        )}
      </div>
    </div>
  );
};

